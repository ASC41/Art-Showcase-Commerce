modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
PRINTIFY_BLUEPRINT_CONFIG = "{\"matte\":{\"blueprintId\":983,\"printProviderId\":95,\"variantIds\":{\"11x14\":78544,\"18x24\":78547,\"24x36\":78549}},\"framed\":{\"blueprintId\":1236,\"printProviderId\":105,\"variantIds\":{\"11x14\":93816,\"18x24\":93822,\"24x36\":93828}}}"
